{
    "name": "mafio69/suite-dev",
    "description": "Developer Suite: Logger + Log Viewer (Symfony)",
    "type": "project",
    "repositories": [
        {
            "type": "path",
            "url": "./time-agent"
        },
        {
            "type": "vcs",
            "url": "https://github.com/mafio69/fast-php-log-viewer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "mafio69/log-viewer": "^1.0",
        "mafio69/fast-php-logger": "^0.9",
        "mafio69/log-viewer": "@dev",
        "mafio69/time-agent": "@dev",
        "symfony/asset": "^7.0",
        "symfony/console": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/flex": "^2.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/messenger": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/yaml": "^7.0",
        "twig/twig": "^3.27"
    },
    "require-dev": {
        "laravel/pint": "^1.10",
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^8.1",
        "symfony/debug-bundle": "^7.0",
        "symfony/phpunit-bridge": "^7.0",
        "symfony/web-profiler-bundle": "^7.0"
    },
    "scripts": {
        "post-install-cmd": [
            "@composer install -d time-agent",
            "@install-hooks"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "start": [
            "docker-compose up -d"
        ],
        "logs": [
            "docker-compose logs -f"
        ],
        "check-env": [
            "php bin/check-env-security"
        ],
        "install-hooks": [
            "@php -r \"if (!is_dir('.git')) exit(0); copy('.githooks/pre-commit', '.git/hooks/pre-commit'); chmod('.git/hooks/pre-commit', 0755); echo 'Git hooks installed\\n';\""
        ],
        "test": [
            "phpunit -c phpunit.xml.dist"
        ],
        "test:unit": [
            "phpunit -c phpunit.xml.dist --testsuite Unit"
        ],
        "test:integration": [
            "phpunit -c phpunit.xml.dist --testsuite Integration"
        ]
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "vendor/laravel/pint/app/",
            "vendor/mafio69/time-agent/src/"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "symfony/thanks": true
        }
    }
}
