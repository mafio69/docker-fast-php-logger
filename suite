#!/bin/bash
# Developer Suite Manager

cd "$(dirname "$0")"

show_help() {
    echo "Developer Suite - zarządzanie"
    echo ""
    echo "Użycie: ./suite [komenda]"
    echo ""
    echo "Komendy:"
    echo "  install     - Instaluj wszystkie komponenty"
    echo "  start       - Uruchom całą suite (docker compose up)"
    echo "  stop        - Zatrzymaj suite"
    echo "  restart     - Restartuj suite"
    echo "  status      - Sprawdź status wszystkich usług"
    echo "  logs        - Pokaż logi (follow)"
    echo "  shell       - Wejdź do kontenera PHP"
    echo ""
    echo     "Komponenty indywidualnie:"
    echo "  mcp:start   - Uruchom MCP Server"
    echo "  mcp:stop    - Zatrzymaj MCP Server"
    echo "  mcp:logs    - Logi MCP Server"
    echo ""
}

case "$1" in
    install)
        echo "📦 Instalacja komponentów..."
        failed=0
        composer install || { echo "ERROR: composer install failed (root)" >&2; failed=1; }
        composer install -d mcp-server || { echo "ERROR: composer install failed (mcp-server)" >&2; failed=1; }
        if [ "$failed" -ne 0 ]; then
            echo "Some components failed to install" >&2
            exit 1
        fi
        echo "Gotowe!"
        ;;
    
    start)
        echo "🚀 Uruchamianie Developer Suite..."
        docker compose up -d
        echo ""
        echo "✅ Suite uruchomiona!"
        echo ""
        echo "Dostępne usługi:"
        echo "  📊 Logger:      http://logs.local"
        echo "  📱 App:         http://app.local"
        echo "  🔧 MCP Server:  http://localhost:8080"
        echo "  🗄️  phpMyAdmin:  http://pma.local"
        echo "  📧 Mailpit:     http://mail.local"
        ;;
    
    stop)
        echo "🛑 Zatrzymywanie..."
        docker compose down
        echo "✅ Zatrzymane"
        ;;
    
    restart)
        echo "🔄 Restart..."
        docker compose restart
        ./suite status
        ;;
    
    status)
        echo "📊 Status kontenerów:"
        docker compose ps
        echo ""
        echo "🌐 Porty:"
        ss -tlnp 2>/dev/null | grep -E "8080|8794|3307" || netstat -tlnp 2>/dev/null | grep -E "8080|8794|3307" || echo "  (brak danych)"
        ;;
    
    logs)
        docker compose logs -f
        ;;
    
    shell)
        docker compose exec php bash
        ;;
    
    mcp:start)
        docker compose up -d mcp-server
        echo "✅ MCP Server: http://localhost:8080"
        ;;
    
    mcp:stop)
        docker compose stop mcp-server
        ;;
    
    mcp:logs)
        docker compose logs -f mcp-server
        ;;
    
    agent:start)
        echo "Time Agent został usunięty z projektu"
        ;;
    
    agent:stop)
        echo "Time Agent został usunięty z projektu"
        ;;
    
    agent:logs)
        echo "Time Agent został usunięty z projektu"
        ;;
    
    snooze)
        echo "Time Agent został usunięty z projektu"
        ;;
    
    bypass)
        echo "Time Agent został usunięty z projektu"
        ;;
    
    *)
        show_help
        ;;
esac
