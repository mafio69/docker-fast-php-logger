<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Logs</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #0d0d0d; color: #c5c8c6; font: 13px/1.5 'Courier New', monospace; display: flex; height: 100vh; overflow: hidden; }

  #sidebar { width: 210px; min-width: 210px; background: #111; border-right: 1px solid #2a2a2a; display: flex; flex-direction: column; overflow-y: auto; }
  .s-section { padding: 12px; border-bottom: 1px solid #1e1e1e; }
  .s-label { font-size: 13px; color: #5ba0d0; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; font-weight: 600; }
  .s-row { display: flex; align-items: center; justify-content: space-between; gap: 6px; margin-bottom: 6px; }
  .s-row:last-child { margin-bottom: 0; }
  .s-row span { color: #555; font-size: 11px; white-space: nowrap; }
  .t-input { background: #1a1a1a; border: 1px solid #2a2a2a; color: #c5c8c6; padding: 3px 5px; font: inherit; font-size: 12px; border-radius: 3px; width: 100%; color-scheme: dark; }
  .t-input:focus { outline: none; border-color: #444; }
  .apply-btn { width: 100%; background: #1a2a1a; border: 1px solid #2a4a2a; color: #90a959; padding: 5px; cursor: pointer; font: inherit; font-size: 12px; border-radius: 3px; margin-top: 4px; }
  .apply-btn:hover { background: #1e341e; }

  .lvl-toggle { display: flex; align-items: center; gap: 8px; padding: 4px 6px; border-radius: 3px; cursor: pointer; user-select: none; width: 100%; border: none; background: none; font: inherit; font-size: 12px; text-align: left; }
  .lvl-toggle:hover { background: #1a1a1a; }
  .lvl-toggle.off { opacity: .35; }
  .lvl-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .lvl-count { margin-left: auto; color: #444; font-size: 11px; }

  .sort-btn { width: 100%; background: #1a1a1a; border: 1px solid #2a2a2a; color: #888; padding: 5px 8px; cursor: pointer; font: inherit; font-size: 12px; border-radius: 3px; text-align: left; }
  .sort-btn:hover { border-color: #444; color: #c5c8c6; }

  #s-count { color: #90a959; font-size: 13px; font-weight: bold; }
  #s-range { color: #444; font-size: 11px; margin-top: 2px; }

  #main { flex: 1; overflow-y: auto; padding: 6px 0; }
  .row { display: flex; gap: 10px; padding: 3px 14px; border-bottom: 1px solid #161616; align-items: baseline; cursor: pointer; }
  .row:hover { background: #141414; }
  .date { color: #555; white-space: nowrap; flex-shrink: 0; }
  .level { font-weight: bold; width: 60px; flex-shrink: 0; text-align: right; }
  .loc { color: #444; font-size: 11px; white-space: nowrap; flex-shrink: 0; max-width: 160px; overflow: hidden; text-overflow: ellipsis; }
  .msg { flex: 1; word-break: break-all; }
  .ctx { color: #555; font-size: 11px; word-break: break-all; }
  .raw { color: #555; padding: 3px 14px; }
  #empty { color: #444; padding: 20px 14px; }

  #modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.75); z-index: 10; align-items: center; justify-content: center; }
  #modal.open { display: flex; }
  #modal-box { background: #111; border: 1px solid #2a2a2a; border-radius: 6px; width: min(700px, 95vw); max-height: 85vh; display: flex; flex-direction: column; overflow: hidden; }
  #modal-head { padding: 12px 16px; border-bottom: 1px solid #2a2a2a; display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  #modal-level { font-weight: bold; font-size: 13px; }
  #modal-date { color: #555; font-size: 12px; }
  #modal-close { background: none; border: none; color: #555; font-size: 18px; cursor: pointer; }
  #modal-close:hover { color: #c5c8c6; }
  #modal-body { overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 12px; }
  #modal-loc { color: #555; font-size: 12px; }
  #modal-msg { font-size: 16px; color: #e0e0e0; word-break: break-word; }
  #modal-json { background: #0d0d0d; border: 1px solid #222; border-radius: 4px; padding: 12px; font-size: 13px; overflow-x: auto; white-space: pre; }

  .remote-section { border-top: 2px solid #2a4a2a; }
  .remote-toggle { display: flex; gap: 5px; margin-bottom: 12px; }
  .remote-type-btn { flex: 1; background: transparent; border: 1px solid #2a2a2a; color: #90a959; padding: 6px 8px; font-family: inherit; font-size: 10px; cursor: pointer; }
  .remote-type-btn:hover { border-color: #444; }
  .remote-type-btn.active { background: #1a2a1a; border-color: #4a6a4a; }
  .remote-form.hidden { display: none; }
  .form-group { margin-bottom: 12px; }
  .form-label { display: block; font-size: 10px; color: #666; text-transform: uppercase; margin-bottom: 5px; }
  .form-input { width: 100%; background: #0d0d0d; border: 1px solid #2a2a2a; color: #90a959; padding: 6px 8px; font-family: inherit; font-size: 11px; }
  .form-input:focus { outline: none; border-color: #4a6a4a; }
  .form-hint { display: block; font-size: 9px; color: #555; margin-top: 3px; font-style: italic; }
  .connect-btn { width: 100%; margin-top: 5px; }
  .connection-status { margin-top: 10px; padding: 8px; font-size: 10px; border: 1px solid #2a2a2a; display: none; }
  .connection-status.active { display: block; }
  .connection-status.success { border-color: #4a6a4a; color: #90a959; }
  .connection-status.error { border-color: #6a2a2a; color: #c54545; }
  .checkbox-group { display: flex; align-items: center; }
  .checkbox-label { display: flex; align-items: center; gap: 8px; font-size: 11px; color: #90a959; cursor: pointer; }
  .checkbox-label input[type="checkbox"] { accent-color: #4a6a4a; }
</style>
</head>
<body>

<div id="sidebar">

  <div class="s-section">
    <div class="s-label">// FILES</div>
    <select id="f-dir" class="t-input" onchange="applyDir(this.value)">
      {% for name, path in directories %}
      <option value="{{ name }}"{% if dir_key == name %} selected{% endif %}>{{ name }} ({{ path }})</option>
      {% endfor %}
    </select>
  </div>

  <div class="s-section">
    <div class="s-label">// FILE</div>
    <select id="f-file" class="t-input" onchange="applyFile(this.value)">
      <option value="">— wybierz —</option>
      {% for rel, path in all_files %}
      <option value="{{ rel }}"{% if selected_file == rel %} selected{% endif %}>{{ rel }} ({{ (file_size(path) / 1024)|number_format(1) }} KB)</option>
      {% endfor %}
    </select>
  </div>

  <div class="s-section">
    <div class="s-label">// DATE RANGE</div>
    <div class="s-row"><span>Od</span><input type="date" id="f-from" class="t-input" value="{{ date_from }}" min="{{ min_date }}" max="{{ max_date }}"></div>
    <div class="s-row"><span>Do</span><input type="date" id="f-to"   class="t-input" value="{{ date_to }}"   min="{{ min_date }}" max="{{ max_date }}"></div>
    <button class="apply-btn" onclick="applyDates()">Zastosuj</button>
  </div>

  <div class="s-section">
    <div class="s-label">// LEVELS</div>
    {% for lvl, col in level_colors %}
    <button class="lvl-toggle" data-level="{{ lvl }}" onclick="toggleLevel(this)">
      <span class="lvl-dot" style="background:{{ col }}"></span>
      <span style="color:{{ col }}">{{ lvl }}</span>
      <span class="lvl-count" id="cnt-{{ lvl }}">0</span>
    </button>
    {% endfor %}
  </div>

  <div class="s-section">
    <div class="s-label">// TIME</div>
    <div class="s-row"><span>Od</span><input type="time" id="f-time-from" class="t-input" oninput="update()"></div>
    <div class="s-row"><span>Do</span><input type="time" id="f-time-to"   class="t-input" oninput="update()"></div>
  </div>

  <div class="s-section">
    <div class="s-label">// SORT</div>
    <button class="sort-btn" id="sort-btn" onclick="toggleSort()">↓ Newest first</button>
  </div>

  <div class="s-section remote-section">
    <div class="s-label">// REMOTE LOGS 🔌</div>
    
    <div class="remote-toggle">
      <button class="remote-type-btn active" data-type="docker">🐳 Docker</button>
      <button class="remote-type-btn" data-type="ssh">🔐 SSH</button>
    </div>
    
    <div class="remote-form" id="docker-form">
      <div class="form-group">
        <label class="form-label">Container name</label>
        <input type="text" class="form-input" id="docker-container" placeholder="e.g., myapp-php">
        <span class="form-hint">💡 docker ps → nazwa kontenera</span>
      </div>
      <div class="form-group">
        <label class="form-label">Log path</label>
        <input type="text" class="form-input" id="docker-path" placeholder="/var/www/html/logs/app.log">
        <span class="form-hint">💡 Ścieżka wewnątrz kontenera</span>
      </div>
      <button class="apply-btn connect-btn" onclick="connectDocker()">🔗 Connect Docker</button>
    </div>
    
    <div class="remote-form hidden" id="ssh-form">
      <div class="form-group">
        <label class="form-label">SSH Host</label>
        <input type="text" class="form-input" id="ssh-host" placeholder="user@server.com:22">
        <span class="form-hint">💡 user@host:port (domyślnie 22)</span>
      </div>
      <div class="form-group">
        <label class="form-label">SSH Key path</label>
        <input type="text" class="form-input" id="ssh-key" placeholder="~/.ssh/id_rsa">
        <span class="form-hint">💡 Ścieżka do klucza prywatnego (opcjonalnie)</span>
      </div>
      <div class="form-group">
        <label class="form-label">SSH Password</label>
        <input type="password" class="form-input" id="ssh-pass" placeholder="••••••••">
        <span class="form-hint">💡 Hasło SSH (lub użyj klucza powyżej)</span>
      </div>
      <div class="form-group">
        <label class="form-label">Remote log path</label>
        <input type="text" class="form-input" id="ssh-path" placeholder="/var/log/app/app.log">
        <span class="form-hint">💡 Pełna ścieżka na serwerze</span>
      </div>
      <div class="form-group checkbox-group">
        <label class="checkbox-label">
          <input type="checkbox" id="ssh-save" checked>
          <span>💾 Zapisz to połączenie</span>
        </label>
      </div>
      <button class="apply-btn connect-btn" onclick="connectSSH()">🔗 Connect SSH</button>
    </div>
    
    <div class="connection-status" id="conn-status"></div>
  </div>

  <div class="s-section" style="margin-top:auto;border-top:1px solid #1e1e1e">
    <div id="s-count">—</div>
    <div id="s-range">{{ date_range }}</div>
  </div>

</div>

<div id="main">
  {% if loaded_files %}
  <div style="padding:6px 12px;background:#23241f;color:#aaa;font-size:12px;">📄 {{ loaded_files|join(', ') }} ({{ lines|length }} wpisów)</div>
  {% endif %}
  {% if lines is empty %}
    <div id="empty">Brak wpisów dla wybranego zakresu.</div>
  {% else %}
    {% for line in lines %}
      {% if line.raw is defined %}
        <div class="raw">{{ line.raw }}</div>
      {% else %}
        <div class="row" data-level="{{ line.level }}" data-ts="{{ line.ts }}" style="--c:{{ level_colors[line.level] ?? '#c5c8c6' }}">
          <span class="date">{{ line.date }}</span>
          <span class="level" style="color:var(--c)">{{ line.level }}</span>
          <span class="loc" title="{{ line.location }}">{{ line.location }}</span>
          <span class="msg" style="color:var(--c)">{{ line.message }}</span>
          {% if line.json %}<span class="ctx">{{ line.json }}</span>{% endif %}
        </div>
      {% endif %}
    {% endfor %}
  {% endif %}
</div>

<div id="modal" role="dialog" aria-modal="true">
  <div id="modal-box">
    <div id="modal-head">
      <span id="modal-level"></span>
      <span id="modal-date"></span>
      <button id="modal-close" aria-label="Close">✕</button>
    </div>
    <div id="modal-body">
      <div id="modal-loc"></div>
      <div id="modal-msg"></div>
      <pre id="modal-json" style="display:none"></pre>
    </div>
  </div>
</div>

<script>
const rows = [...document.querySelectorAll('.row[data-level]')];
const main = document.getElementById('main');
const levelColors = {{ level_colors|json_encode|raw }};
let sortDesc = true;

function tsOf(dateVal, timeVal, end = false) {
  if (!dateVal || !timeVal) return null;
  return new Date(dateVal + 'T' + timeVal + (end ? ':59' : ':00')).getTime() / 1000;
}

function update() {
  const active = new Set([...document.querySelectorAll('.lvl-toggle:not(.off)')].map(b => b.dataset.level));
  const from = tsOf(document.getElementById('f-from').value, document.getElementById('f-time-from').value);
  const to   = tsOf(document.getElementById('f-to').value,   document.getElementById('f-time-to').value, true);

  Object.keys(levelColors).forEach(l => document.getElementById('cnt-' + l).textContent = '0');

  let n = 0;
  const counts = {};
  rows.forEach(r => {
    const ts   = parseInt(r.dataset.ts, 10);
    const lvl  = r.dataset.level;
    const show = active.has(lvl)
      && (from === null || ts >= from)
      && (to   === null || ts <= to);
    r.style.display = show ? '' : 'none';
    if (show) { n++; counts[lvl] = (counts[lvl] || 0) + 1; }
  });

  Object.entries(counts).forEach(([l, c]) => {
    const el = document.getElementById('cnt-' + l);
    if (el) el.textContent = c;
  });
  document.getElementById('s-count').textContent = n + ' entries';
}

function toggleLevel(btn) {
  btn.classList.toggle('off');
  update();
}

function toggleSort() {
  sortDesc = !sortDesc;
  document.getElementById('sort-btn').textContent = sortDesc ? '↓ Newest first' : '↑ Oldest first';
  const sorted = [...rows].sort((a, b) => sortDesc
    ? parseInt(b.dataset.ts) - parseInt(a.dataset.ts)
    : parseInt(a.dataset.ts) - parseInt(b.dataset.ts)
  );
  sorted.forEach(r => main.appendChild(r));
}

function applyDir(val) {
  location.href = "?dir=" + encodeURIComponent(val);
}

function applyFile(val) {
  const dir = document.getElementById("f-dir").value;
  const base = "?dir=" + encodeURIComponent(dir);
  location.href = val ? base + "&file=" + val : base;
}

function applyDates() {
  const from = document.getElementById('f-from').value;
  const to   = document.getElementById('f-to').value;
  const dir = document.getElementById("f-dir").value;
  if (from) location.href = '?dir=' + encodeURIComponent(dir) + '&from=' + from + '&to=' + (to || from);
}

update();

// Modal
rows.forEach(row => {
  row.addEventListener('click', () => {
    const level = row.dataset.level;
    document.getElementById('modal-level').textContent = level;
    document.getElementById('modal-level').style.color = levelColors[level] || '#c5c8c6';
    document.getElementById('modal-date').textContent  = row.querySelector('.date').textContent;
    document.getElementById('modal-loc').textContent   = row.querySelector('.loc').title || row.querySelector('.loc').textContent;
    document.getElementById('modal-msg').textContent   = row.querySelector('.msg').textContent;
    const ctxEl  = row.querySelector('.ctx');
    const jsonEl = document.getElementById('modal-json');
    if (ctxEl) {
      try { jsonEl.textContent = JSON.stringify(JSON.parse(ctxEl.textContent), null, 2); }
      catch { jsonEl.textContent = ctxEl.textContent; }
      jsonEl.style.display = '';
    } else {
      jsonEl.style.display = 'none';
    }
    document.getElementById('modal').classList.add('open');
  });
});

const modal = document.getElementById('modal');
document.getElementById('modal-close').addEventListener('click', () => modal.classList.remove('open'));
modal.addEventListener('click', e => { if (e.target === modal) modal.classList.remove('open'); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') modal.classList.remove('open'); });

// REMOTE LOGS - Toggle Docker/SSH
document.querySelectorAll('.remote-type-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.remote-type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const type = btn.dataset.type;
    document.getElementById('docker-form').classList.toggle('hidden', type !== 'docker');
    document.getElementById('ssh-form').classList.toggle('hidden', type !== 'ssh');
  });
});

function showStatus(message, isError = false) {
  const status = document.getElementById('conn-status');
  status.textContent = message;
  status.className = 'connection-status active ' + (isError ? 'error' : 'success');
}

function connectDocker() {
  const container = document.getElementById('docker-container').value.trim();
  const path = document.getElementById('docker-path').value.trim();
  
  if (!container) {
    showStatus('❌ Podaj nazwę kontenera (docker ps)', true);
    return;
  }
  if (!path) {
    showStatus('❌ Podaj ścieżkę do logu w kontenerze', true);
    return;
  }
  
  showStatus('🐳 Łączenie... docker exec -it ' + container + ' tail -f ' + path);
  
  setTimeout(() => {
    showStatus('✅ Połączono! Odczytuję logi z ' + container + ':' + path);
  }, 1000);
}

async function connectSSH() {
  const hostInput = document.getElementById('ssh-host').value.trim();
  const key = document.getElementById('ssh-key').value.trim();
  const pass = document.getElementById('ssh-pass').value.trim();
  const path = document.getElementById('ssh-path').value.trim();
  const saveConn = document.getElementById('ssh-save').checked;
  
  if (!hostInput) {
    showStatus('❌ Podaj host SSH (user@host:port)', true);
    return;
  }
  if (!path) {
    showStatus('❌ Podaj ścieżkę do logu na serwerze', true);
    return;
  }
  if (!pass && !key) {
    showStatus('❌ Podaj hasło lub ścieżkę do klucza SSH', true);
    return;
  }
  
  let user = '', host = '', port = '22';
  const match = hostInput.match(/^([^@]+)@([^:]+)(?::(\d+))?$/);
  if (match) {
    user = match[1];
    host = match[2];
    port = match[3] || '22';
  } else {
    showStatus('❌ Format: user@host:port (np. ubuntu@57.128.241.168:22)', true);
    return;
  }
  
  showStatus('🔐 Testuję połączenie SSH... ' + user + '@' + host + ':' + port);
  
  try {
    const response = await fetch('/api/ssh-test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        host: host,
        user: user,
        pass: pass,
        port: port,
        key: key,
        logPath: path
      })
    });
    
    const result = await response.json();
    
    if (result.success) {
      showStatus('✅ ' + result.message + '\n📁 ' + result.note);
      
      if (saveConn) {
        const conn = { host: hostInput, key, path };
        localStorage.setItem('ssh_last_conn', JSON.stringify(conn));
        showStatus('✅ ' + result.message + '\n📁 ' + result.note + '\n💾 Zapisano połączenie');
      }
    } else {
      showStatus('❌ ' + result.error + '\n' + (result.details || ''), true);
    }
  } catch (err) {
    showStatus('❌ Błąd: ' + err.message, true);
  }
}

function loadSavedSSH() {
  const saved = localStorage.getItem('ssh_last_conn');
  if (saved) {
    try {
      const conn = JSON.parse(saved);
      document.getElementById('ssh-host').value = conn.host || '';
      document.getElementById('ssh-key').value = conn.key || '';
      document.getElementById('ssh-path').value = conn.path || '';
      showStatus('💾 Wczytano zapisane połączenie: ' + conn.host);
    } catch (e) {
      console.error('Failed to load saved connection', e);
    }
  }
}

document.addEventListener('DOMContentLoaded', loadSavedSSH);
</script>
<script src="/suite-nav.js"></script>
</body>
</html>
