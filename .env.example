# ----------------------------------------------------
# Docker Environment Variables
# ----------------------------------------------------
# These variables are used by docker-compose to configure the services.
# You can copy this file to .env and customize the values.

# --- Port Mapping ---
# Format: <host-port>:<container-port>
PHP_PORT=8082
DB_PORT=3307
ADMINER_PORT=8081
PORTAINER_PORT=9090
MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025
PROXY_PORT=80

# --- Database Credentials ---
# These are used to initialize the MySQL container and connect the PHP application.
DB_DATABASE=devbox
DB_USERNAME=devbox
DB_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme
DATABASE_URL="mysql://devbox:changeme@mysql:3306/devbox?serverVersion=8.0&charset=utf8mb4"

# ----------------------------------------------------
# Application Environment Variables
# ----------------------------------------------------
# These variables are used by the Symfony application inside the container.

# --- Mailer Configuration ---
# Points to the Mailpit service.
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=dev@localhost

# --- GitHub API Access ---
# Optional: Provide a token for higher rate limits with Composer.
GIT_ACCESS_TOKEN=

# --- SSH Test Endpoint ---
# Credentials for the SSH test functionality.
# Leave SSH_TEST_TOKEN empty to disable the endpoint.
SSH_TEST_TOKEN=
SSH_TEST_HOST=frog01.mikr.us
SSH_TEST_USER=frog
SSH_TEST_PORT=10137
SSH_TEST_PASSWORD=
